POSTGRES_DB=aethervault
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

MONGO_URI=mongodb://username:password@host1:27017,host2:27017,host3:27017/aethervault?ssl=true&replicaSet=your-replica-set&authSource=admin&appName=Cluster0

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/aethervault
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_postgres_password
JWT_SECRET=replace-with-at-least-32-characters-for-hmac
UPLOAD_DIR=uploads
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@aethervault.local
ADMIN_PASSWORD=change-this-admin-password

SPRING_BACKEND_URL=http://localhost:8080
NODE_BACKEND_URL=http://localhost:5000
GATEWAY_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000
