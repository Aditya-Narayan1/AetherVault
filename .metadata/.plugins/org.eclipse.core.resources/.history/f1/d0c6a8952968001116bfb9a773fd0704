server.port=8080

# PostgreSQL
spring.datasource.url=jdbc:postgresql://localhost:5432/aethervault
spring.datasource.username=postgres
spring.datasource.password=aditya8505
spring.datasource.driver-class-name=org.postgresql.Driver

# Hibernate / JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# JWT
jwt.secret=change-this-development-secret-change-this
jwt.expiration-ms=86400000

# Uploads
app.upload-dir=uploads

# Node Backend
node.backend-url=http://localhost:5000

# Default Admin
app.admin.username=admin
app.admin.email=admin@aethervault.local
app.admin.password=admin123

# Multipart Upload Limits
spring.servlet.multipart.max-file-size=20MB
spring.servlet.multipart.max-request-size=20MB

# Logging
logging.level.org.springframework=INFO
logging.level.org.hibernate.SQL=INFO

# OpenAPI / Swagger
springdoc.swagger-ui.path=/swagger-ui.html
springdoc.api-docs.path=/v3/api-docs